# ============================================================
# Variables d'environnement — À coller dans Railway
# ============================================================

# eBay API (TOI SEUL tu les mets ici — tes utilisateurs ne les voient jamais)
EBAY_CLIENT_ID=TonNom-ArbitrageX-PRD-xxxxxxxxx
EBAY_CLIENT_SECRET=PRD-xxxxxxxxxxxxxxxxx

# Base de données Supabase (copie l'URL depuis Supabase → Settings → Database)
DATABASE_URL=postgresql://postgres:TON_MOT_DE_PASSE@db.xxxxxx.supabase.co:5432/postgres

# Clé secrète pour chiffrer les tokens (invente n'importe quelle suite de caractères longue)
SECRET_KEY=une-longue-cle-secrete-que-tu-inventes-arbitragex-2024

# Fréquence de scan en minutes
SCAN_INTERVAL_MINUTES=5

# Alertes Discord (optionnel)
DISCORD_WEBHOOK_URL=

# Alertes Telegram (optionnel)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
